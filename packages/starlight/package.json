{
  "name": "@nebari/starlight",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Shared Starlight theme plugin for Nebari documentation sites.",
  "keywords": ["starlight", "astro", "nebari", "theme", "documentation"],
  "homepage": "https://github.com/nebari-dev/starlight#readme",
  "repository": { "type": "git", "url": "git+https://github.com/nebari-dev/starlight.git", "directory": "packages/starlight" },
  "publishConfig": { "access": "public" },
  "files": ["dist", "src/styles", "src/fonts", "src/assets", "src/components"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/*": "./src/styles/*",
    "./fonts/*": "./src/fonts/*",
    "./components/*": "./src/components/*"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.33.0 <1.0.0",
    "astro": ">=5.0.0 <6.0.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.33.0",
    "astro": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
